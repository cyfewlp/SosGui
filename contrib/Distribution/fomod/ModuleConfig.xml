<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://qconsulting.ca/fo3/ModConfig5.0.xsd">
    <moduleName>ImGui extender for Skyrim Outfit System SE - SosGui</moduleName>
    <moduleImage path="fomod\sosgui_character_edit.jpg"/>

	<moduleDependencies operator="And">
		<fileDependency file="SkyrimOutfitSystem.esp" state="Active"/>
	</moduleDependencies>

    <requiredInstallFiles>
        <folder source="Source" destination="Source"/>
        <folder source="SKSE" destination="SKSE"/>
        <folder source="Scripts" destination="Scripts"/>
        <folder source="interface" destination="interface"/>
        <file source="SosGui.esp" destination="SosGui.esp" />
    </requiredInstallFiles>

    <installSteps order="Explicit">
        <installStep name="Language">
            <optionalFileGroups order="Explicit">
                <group name="Select Language" type="SelectExactlyOne">
                    <plugins order="Explicit">
                        <plugin name="English (Default)">
                            <description>
                                <![CDATA[Use English. No settings file is installed; English is always the fallback.]]>
                            </description>
                            <files>
                                <file source="lang\english\sosgui_settings.toml" destination="interface\SosGui\sosgui_settings.toml"/>
                            </files>
                            <typeDescriptor>
                                <type name="Recommended"/>
                            </typeDescriptor>
                        </plugin>
                        <plugin name="Chinese (中文)">
                            <description>
                                <![CDATA[Use Simplified Chinese. Installs sosgui_settings.toml with language = "chinese".]]>
                            </description>
                            <files>
                                <file source="lang\chinese\sosgui_settings.toml" destination="interface\SosGui\sosgui_settings.toml"/>
                            </files>
                            <typeDescriptor>
                                <type name="Optional"/>
                            </typeDescriptor>
                        </plugin>
                    </plugins>
                </group>
            </optionalFileGroups>
        </installStep>
    </installSteps>
</config>